{
  "crons": [
    {
      "path": "/api/cron/abandoned-cart-reminders",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/archive-expired-galleries",
      "schedule": "15 15 * * *"
    },
    {
      "path": "/api/cron/stripe-billing-sync",
      "schedule": "0 4 * * *"
    }
  ],
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- . ':(exclude)CLAUDE.md' ':(exclude)docs/' ':(exclude)supabase/migrations/' ':(exclude)*.md' ':(exclude).gitignore' ':(exclude)tmp_*' ':(exclude)tmp-*'"
}
